---
import { HeroSlider1, HeroSlider2, HeroSlider3 } from "@static/images";
import Layout from "../layouts/Layout.astro";
import { Hero } from "@modules/Hero";
import WhatsAppButton from "../components/WhatsAppButton.astro";
---

<Layout
  title="Dalopeza | Webdeveloper & Designer"
  description="Soy desarrollador web y diseñador gráfico, con 10 años de experiencia mi trabajo es conceptual basado en el logo, slogan y colores de su marca."
>
  <main class="page-content">
    <Hero
      client:load
      heroType="fullPageSlider"
      data={[
        {
          subtitle: "Webdeveloper & Designer",
          title: "Dalo",
          background: HeroSlider1.src,
          paragraph:
            "Diseño y desarrollo webs que convierten visitantes en clientes. Con 14 años de experiencia, cada proyecto lo construyo desde tu marca: tu logo, tus colores, tu esencia. React, Next.js, Astro, Node.js y más — siempre con resultados reales.",
          button: {
            text: "Portafolio",
            link: "/portafolio",
          },
        },
        {
          subtitle: "Front-end / Back-end",
          title: "Soluciones",
          background: HeroSlider3.src,
          paragraph: "",
          button: {
            text: "Echa un vistazo",
            link: "/infinite",
          },
        },
        {
          subtitle: "Ux / Ui",
          title: "Designer",
          background: HeroSlider2.src,
          paragraph:
            "Desde 2007 creo identidades visuales que conectan marcas con personas. UI/UX, branding, presentaciones y más — siempre partiendo de lo que hace única a tu empresa.",
          button: {
            text: "Contactame",
            link: "/contasct",
          },
        },
      ]}
    />
    <WhatsAppButton />
  </main>
</Layout>
