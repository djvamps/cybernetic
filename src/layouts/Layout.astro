---
import { NormalizeCSS } from "../styles/normalize";
import { Global } from "@emotion/react";
import { PreviewPng } from "@static/images";
import { Header } from "@modules/Header";
import MetaConfig from "./MetaConfig.astro";

interface Props {
  title: string;
  description: string;
  overwritePreview?: string;
}

const { title, description, overwritePreview } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head> b 

    <!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-4CZDE3X8XS"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-4CZDE3X8XS');
</script>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"
    />

    <MetaConfig
      title={title}
      description={description}
      preview={overwritePreview ? overwritePreview : PreviewPng.src}
    />
    <title>{title}</title>
    <Global styles={NormalizeCSS} />

    <script>
      /**
       * Add class to transition "overflow element" on page load to make it prettier
       */
      document.addEventListener("DOMContentLoaded", () => {
        document.body.classList.add("hide-overflow");
      });
    </script>
  </head>
  <body>
    <Header client:load />
    <slot />
  </body>
</html>
